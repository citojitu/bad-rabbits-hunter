# ---- Required ----

# Ethereum mainnet RPC. Alchemy / Infura / your own node — anything reliable.
# DO NOT commit the real URL if it has an API key embedded.
ETH_RPC=https://your-rpc-endpoint.example/v2/YOUR_API_KEY

# Wallet to mint from. Funds it with enough ETH to cover hunt fee + gas.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# The Bad Rabbits Hunt contract address.
BAD_RABBITS_CONTRACT=0x22fDb6b9573F67b7f564a7d80629c64672985839

# ---- Optional ----

# Chain id (auto-detected from RPC, this is informational only).
CHAIN_ID=1

# How many CPU worker threads to spawn for mining.
# Default = cpus().length - 1. Bump to cpus().length for max throughput.
# WORKERS=11

# Private RPCs for tx broadcast (comma-separated). Defaults bundle Flashbots
# Fast + MEV Blocker. Override to add/remove endpoints.
# MEV_RPCS=https://rpc.flashbots.net/fast,https://rpc.mevblocker.io

# Priority fee in gwei for the mint tx. Default 2 (normal high-priority).
# Bump for more aggressive bidding, but remember: priority × ~80k gas is paid
# on every successful inclusion.
# PRIORITY_GWEI=2

# How often to re-poll currentChallenge() during mining (ms).
# Default 3000. Lower = quicker race detection, more RPC calls.
# CHALLENGE_POLL_MS=3000

# ---- Telegram notifications (optional) ----

# Get bot token from @BotFather on Telegram.
# Get your chat id by sending /start to your bot then visiting:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
